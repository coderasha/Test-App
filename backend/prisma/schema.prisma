generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  employees   Employee[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Employee {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?
  position     String
  salary       Float?
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  hireDate     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
